# Copy to backend/.env for local dev. Without these, prediction history falls
# back to a local libSQL file at app/data/store/predictions.db (git-ignored).
# Set both on Render too, so history survives redeploys there.
TURSO_DATABASE_URL=libsql://<your-db-name>-<your-org>.turso.io
TURSO_AUTH_TOKEN=<token from `turso db tokens create <your-db-name>`>
